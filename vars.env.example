# ============================================================================
# TULL HYDROPONICS - Local Development Environment Variables
# ============================================================================
# Copy this file to vars.env and fill in your values
# 
# cp vars.env.example vars.env
#
# NEVER commit vars.env to version control!
# ============================================================================

# Flask Configuration
FLASK_SECRET_KEY=your_dev_secret_key_here
FLASK_ENV=development

# Main Domain (for Stripe redirects)
MAIN_DOMAIN=http://localhost:5000

# ============================================================================
# STRIPE CONFIGURATION
# ============================================================================
# For local development, use Stripe TEST mode keys
# Get from: https://dashboard.stripe.com/test/apikeys

STRIPE_SECRET_KEY=sk_test_your_test_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_test_key_here

# Webhook secret for local testing
# Use Stripe CLI: stripe listen --forward-to localhost:5000/webhook
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Price ID for your test product
HP_PRICE_ID=price_your_test_price_id_here

# ============================================================================
# POSTMARK CONFIGURATION
# ============================================================================
# For transactional emails (feedback confirmations, order emails)
# Get from: https://account.postmarkapp.com/servers

POSTMARK_SERVER_TOKEN=your_postmark_server_token_here
POSTMARK_SENDER_EMAIL=support@tullhydro.com

# ============================================================================
# ADMIN BOOTSTRAP (first-run only)
# ============================================================================
# Creates the initial admin account when the database is empty.
# After bootstrap, manage all accounts via TullOps admin API.

ADMIN_BOOTSTRAP_EMAIL=admin
ADMIN_BOOTSTRAP_PASSWORD=admin123
ADMIN_BOOTSTRAP_DISPLAY_NAME=Admin

# ============================================================================
# ADMIN API KEY (for TullOps remote management)
# ============================================================================
ADMIN_API_KEY=your_admin_api_key_here

# ============================================================================
# SECURITY THRESHOLDS
# ============================================================================
AUTO_BAN_THRESHOLD=20
AUTO_BAN_WINDOW_HOURS=1

# ============================================================================
# LOCAL TESTING NOTES
# ============================================================================
#
# 1. STRIPE WEBHOOKS:
#    Install Stripe CLI and run:
#    stripe listen --forward-to localhost:5000/webhook
#    
#    Copy the webhook signing secret it provides to STRIPE_WEBHOOK_SECRET
#
# 2. TEST PAYMENTS:
#    Use Stripe test card: 4242 4242 4242 4242
#    Any future expiry date and any CVC
#
# 3. DATABASE:
#    SQLite database will be created at tullhydro.db in project root
#    Delete this file to reset the database
#
# ============================================================================
