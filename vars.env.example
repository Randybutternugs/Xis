# ============================================================================
# TULL HYDROPONICS - Local Development Environment Variables
# ============================================================================
# Copy this file to vars.env and fill in your values
# 
# cp vars.env.example vars.env
#
# NEVER commit vars.env to version control!
# ============================================================================

# Flask Configuration
FLASK_SECRET_KEY=your_dev_secret_key_here
FLASK_ENV=development

# Main Domain (for Stripe redirects)
MAIN_DOMAIN=http://localhost:5000

# ============================================================================
# STRIPE CONFIGURATION
# ============================================================================
# For local development, use Stripe TEST mode keys
# Get from: https://dashboard.stripe.com/test/apikeys

STRIPE_SECRET_KEY=sk_test_your_test_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_test_key_here

# Webhook secret for local testing
# Use Stripe CLI: stripe listen --forward-to localhost:5000/webhook
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Price ID for your test product
HP_PRICE_ID=price_your_test_price_id_here

# ============================================================================
# MAILGUN CONFIGURATION
# ============================================================================
# For local testing, you can use sandbox domain
# Get from: https://app.mailgun.com/app/account/security/api_keys

MAIL_KEY=your_mailgun_api_key_here

# ============================================================================
# ADMIN CREDENTIALS
# ============================================================================
# Generate hashes with:
# python -c "from werkzeug.security import generate_password_hash; print(generate_password_hash('your_value'))"

# Example: hashed value of "admin"
ADMIN_USERNAME_HASH=scrypt:32768:8:1$RkmSaBoEJHHEOrob$a436468c6580b68f67c3fdd733a7c52c38da768ee6dd9414da8dbdafa78ae5f92e0793fc613a78a9cd6ea5312abd5d23faf868eb0e0d2e1f52a06d1164547718

# Example: hashed value of "password123"
ADMIN_PASSWORD_HASH=scrypt:32768:8:1$zOlfRPNfqJrkzdpu$94f1b0d718e1e0363f1fe709065c9d4b229819b03bb9e85c6bb61dc9f2737435e2dca08331f37a08fe2e9c70f68f0018a3a9ebb97e06d1e2f91363def8c535f6

# ============================================================================
# INVESTOR CREDENTIALS
# ============================================================================
# Separate login credentials for investors to access the investor portal
# Generate hashes with the same method as admin credentials

# Example: hashed value of "investor"
INVESTOR_USERNAME_HASH=scrypt:32768:8:1$EXAMPLE$replacewithrealhashedvalue

# Example: hashed value of "investorpass"
INVESTOR_PASSWORD_HASH=scrypt:32768:8:1$EXAMPLE$replacewithrealhashedvalue

# ============================================================================
# LOCAL TESTING NOTES
# ============================================================================
#
# 1. STRIPE WEBHOOKS:
#    Install Stripe CLI and run:
#    stripe listen --forward-to localhost:5000/webhook
#    
#    Copy the webhook signing secret it provides to STRIPE_WEBHOOK_SECRET
#
# 2. TEST PAYMENTS:
#    Use Stripe test card: 4242 4242 4242 4242
#    Any future expiry date and any CVC
#
# 3. DATABASE:
#    SQLite database will be created at tullhydro.db in project root
#    Delete this file to reset the database
#
# ============================================================================
