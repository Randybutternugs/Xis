# ============================================================================
# TULL HYDROPONICS - Google App Engine Configuration
# ============================================================================
# Deploy with: gcloud app deploy
# View logs: gcloud app logs tail -s default
# ============================================================================

runtime: python312

# Entry point - uses gunicorn for production
entrypoint: gunicorn -b :$PORT main:app

# Service name (default is the main service)
service: default

# ============================================================================
# ENVIRONMENT VARIABLES
# ============================================================================
# IMPORTANT: Replace all placeholder values before deploying!
# 
# To generate secure keys:
#   python -c "import secrets; print(secrets.token_hex(32))"
#
# Admin bootstrap password is used only on first run to create the initial admin account.
# After that, manage accounts via TullOps admin API.
# ============================================================================

env_variables:
  # Flask Configuration
  FLASK_SECRET_KEY: "REPLACE_WITH_SECURE_RANDOM_KEY"
  FLASK_ENV: "production"
  
  # Your production domain (update this!)
  MAIN_DOMAIN: "https://YOUR_PROJECT_ID.appspot.com"
  
  # Stripe API Keys
  # Get these from: https://dashboard.stripe.com/apikeys
  STRIPE_SECRET_KEY: "sk_live_REPLACE_WITH_YOUR_KEY"
  STRIPE_PUBLISHABLE_KEY: "pk_live_REPLACE_WITH_YOUR_KEY"
  STRIPE_WEBHOOK_SECRET: "whsec_REPLACE_WITH_YOUR_KEY"
  
  # Stripe Product Price ID
  # Create a product in Stripe Dashboard and get the Price ID
  HP_PRICE_ID: "price_REPLACE_WITH_YOUR_PRICE_ID"
  
  # Postmark API for transactional emails
  # Get from: https://account.postmarkapp.com/servers
  POSTMARK_SERVER_TOKEN: "REPLACE_WITH_YOUR_POSTMARK_TOKEN"
  POSTMARK_SENDER_EMAIL: "support@tullhydro.com"
  
  # Admin Bootstrap (first-run only — creates initial admin account)
  ADMIN_BOOTSTRAP_EMAIL: "admin"
  ADMIN_BOOTSTRAP_PASSWORD: "REPLACE_WITH_SECURE_PASSWORD"
  ADMIN_BOOTSTRAP_DISPLAY_NAME: "Admin"

  # Admin API Key (for TullOps remote management)
  ADMIN_API_KEY: "REPLACE_WITH_SECURE_API_KEY"

  # Security Thresholds
  AUTO_BAN_THRESHOLD: "20"
  AUTO_BAN_WINDOW_HOURS: "1"

# ============================================================================
# SCALING CONFIGURATION
# ============================================================================
# Automatic scaling adjusts instances based on traffic
# IMPORTANT: max_instances must be 1 while using SQLite (/tmp is per-instance,
# so multiple instances = multiple independent databases). Increase only after
# migrating to Cloud SQL.
# ============================================================================

automatic_scaling:
  min_instances: 1
  max_instances: 1
  max_concurrent_requests: 50
  target_cpu_utilization: 0.65

# ============================================================================
# REQUEST HANDLERS
# ============================================================================
# Static files are served directly by App Engine (faster)
# All other requests go to the Flask app
# ============================================================================

handlers:
  # Static files (CSS, JS, images, fonts)
  - url: /static
    static_dir: xissite/static
    secure: always
    http_headers:
      Cache-Control: "public, max-age=3600"

  # Favicon
  - url: /favicon.ico
    static_files: xissite/static/icons/favicon.svg
    upload: xissite/static/icons/favicon.svg
    mime_type: image/svg+xml
    secure: always

  # All other URLs handled by Flask
  - url: /.*
    script: auto
    secure: always

# ============================================================================
# NETWORK & SECURITY
# ============================================================================

network:
  session_affinity: true

inbound_services:
  - warmup

# ============================================================================
# INSTANCE CLASS
# ============================================================================
# F1 is the default (256MB RAM, 600MHz CPU)
# Upgrade to F2 or F4 for more resources if needed
# ============================================================================

instance_class: F1

# ============================================================================
# DEPLOYMENT NOTES
# ============================================================================
#
# 1. BEFORE FIRST DEPLOY:
#    - Replace ALL placeholder values above
#    - Set up Stripe account and create products
#    - Set up Mailgun account and verify domain
#    - Generate secure admin credentials
#
# 2. DATABASE:
#    This config uses SQLite stored in /tmp (ephemeral storage)
#    Data will be lost on instance restart!
#    
#    For production, consider:
#    - Cloud SQL (PostgreSQL/MySQL) for persistent storage
#    - Firestore for NoSQL storage
#
# 3. STRIPE WEBHOOKS:
#    After deploying, set up webhook endpoint in Stripe:
#    URL: https://YOUR_PROJECT_ID.appspot.com/webhook
#    Events: checkout.session.completed, checkout.session.async_payment_succeeded
#
# 4. CUSTOM DOMAIN:
#    - Go to App Engine > Settings > Custom Domains
#    - Add your domain (e.g., tullhydro.com)
#    - Update MAIN_DOMAIN env variable
#
# ============================================================================
